{
  "name": "matchexec",
  "version": "0.7.2",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "npm run build:all-processes && next build",
    "build:discord-bot": "node esbuild.discord-bot.config.mjs",
    "build:scheduler": "node esbuild.scheduler.config.mjs",
    "build:migrator": "node esbuild.migrator.config.mjs",
    "build:all-processes": "npm run build:discord-bot && npm run build:scheduler && npm run build:migrator",
    "start": "next start",
    "lint": "eslint .",
    "migrate": "npx tsx scripts/migrate-background.ts",
    "dev:all": "NODE_ENV=development npx pm2 start ecosystem.config.js",
    "dev:stop": "NODE_ENV=development npx pm2 stop ecosystem.config.js",
    "dev:restart": "NODE_ENV=development npx pm2 restart ecosystem.config.js",
    "dev:logs": "npx pm2 logs",
    "typecheck": "npx tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:changed": "vitest run --changed",
    "test:unit": "vitest run --exclude='**/integration/**' --exclude='**/e2e/**'",
    "test:integration": "vitest run tests/integration",
    "test:all": "npm run test",
    "prod:start": "npx pm2 start ecosystem.config.js",
    "prod:stop": "npx pm2 stop ecosystem.config.js",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'npm run typecheck'"
    ]
  },
  "dependencies": {
    "@discordjs/voice": "0.19.1",
    "@mantine/core": "8.3.16",
    "@mantine/dates": "8.3.16",
    "@mantine/form": "8.3.16",
    "@mantine/hooks": "8.3.16",
    "@mantine/modals": "8.3.16",
    "@mantine/notifications": "8.3.16",
    "@snazzah/davey": "0.1.10",
    "@tabler/icons-react": "3.40.0",
    "bufferutil": "4.1.0",
    "discord.js": "14.25.1",
    "express": "5.2.1",
    "framer-motion": "12.35.1",
    "lucide-react": "0.577.0",
    "next": "16.1.7",
    "node-cron": "4.2.1",
    "node-fetch": "3.3.2",
    "pm2": "6.0.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sqlite3": "6.0.1",
    "umzug": "3.8.2",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.2.1",
    "@types/express": "5.0.6",
    "@types/node": "25.3.5",
    "@types/node-cron": "3.0.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "esbuild": "0.27.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.7",
    "happy-dom": "20.8.4",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tailwindcss": "4.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
