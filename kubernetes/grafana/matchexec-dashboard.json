  "schemaVersion": 39,
  "tags": ["matchexec", "discord", "gaming"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MatchExec - Match Bot Dashboard",
  "uid": "matchexec-overview",
  "version": 1
}
