      "type": "stat",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_matches_created_24h", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "cyan", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 6 },
      "id": 14,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Match Participants",
      "type": "stat",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_match_participants_total", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "cyan", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 6 },
      "id": 15,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Tournament Participants",
      "type": "stat",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_tournament_participants_total", "legendFormat": "", "refId": "A" }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "title": "Matches by Status",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_matches_total", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "title": "Tournaments by Status",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_tournaments_total", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 102,
      "title": "Resource Usage",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_memory_rss_bytes", "legendFormat": "RSS", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_memory_heap_used_bytes", "legendFormat": "Heap Used", "refId": "B" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_memory_heap_total_bytes", "legendFormat": "Heap Total", "refId": "C" }
      ]
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Database Size Over Time",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_database_size_bytes", "legendFormat": "DB Size", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 103,
      "title": "Discord Operations",
      "type": "row"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20 }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "id": 40,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Discord Queue Depth",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "matchexec_discord_queue_pending", "legendFormat": "Pending Items", "refId": "A" }
